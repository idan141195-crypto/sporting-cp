# ─── Meta Graph API ──────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=           # Long-Lived Token (60-day expiry)
META_AD_ACCOUNT_ID=          # Format: act_XXXXXXXXXX
META_API_VERSION=v20.0

# ─── Inventory Source ────────────────────────────────────────────────────────
INVENTORY_SOURCE=csv         # "shopify" | "csv"

# Shopify (only required if INVENTORY_SOURCE=shopify)
SHOPIFY_STORE_URL=           # https://yourstore.myshopify.com
SHOPIFY_ACCESS_TOKEN=

# CSV (only required if INVENTORY_SOURCE=csv)
INVENTORY_CSV_PATH=./data/inventory.csv

# ─── Site Health Check ───────────────────────────────────────────────────────
# Endpoint must return JSON: { "status": "GREEN" } or { "status": "RED" }
# If omitted, site health check is skipped (treated as GREEN)
SITE_HEALTH_URL=

# ─── Scheduler ───────────────────────────────────────────────────────────────
CRON_SCHEDULE=*/15 * * * *   # Every 15 minutes

# ─── Safety Guardrails ───────────────────────────────────────────────────────
MAX_BUDGET_CHANGE_PCT=30     # Max cumulative % change per ad set per day
MAX_CHANGES_PER_DAY=5        # Max number of budget changes per ad set per day

# ─── Budget Caps ──────────────────────────────────────────────────────────────
GLOBAL_DAILY_MAX=0           # Max total daily_budget across ALL active ad sets (USD); 0 = disabled
MIN_SCALE_INTERVAL_HOURS=24  # Hours between SCALE actions on the same ad set (Meta learning phase)

# ─── Alerting ─────────────────────────────────────────────────────────────────
ALERT_WEBHOOK_URL=           # Slack incoming webhook -OR- Discord webhook URL
TELEGRAM_BOT_TOKEN=          # Optional: Telegram bot token
TELEGRAM_CHAT_ID=            # Optional: Telegram chat/channel ID
ALERT_EMAIL_TO=              # Optional: recipient for daily email summary
ALERT_MIN_LEVEL=WARNING      # Minimum level to fire webhook: INFO | WARNING | CRITICAL

# ─── Heartbeat ────────────────────────────────────────────────────────────────
HEARTBEAT_FAIL_THRESHOLD=3   # Consecutive Meta API failures before CRITICAL alert
